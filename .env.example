# Telegram API credentials
# Get these from https://my.telegram.org/apps → "API development tools"
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Your Telegram phone number (with country code, e.g. +251912345678)
TELEGRAM_PHONE=+1234567890

# Gemini API key — required only when matcher: ai is set in config.yaml
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Path to store Telegram session file (default: telefeed.session)
SESSION_FILE=telefeed.session

# SQLite database path (default: telefeed.db)
DB_PATH=telefeed.db

# Path to your config file (default: config.yaml)
CONFIG_PATH=config.yaml
